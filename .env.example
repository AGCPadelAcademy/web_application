# Supabase project credentials
# Copy this file to ".env" (or ".env.local") and fill in your own values.
# Vite only exposes env vars prefixed with VITE_ to the client.
# The anon key is safe to expose publicly; the service-role key must NEVER be in the client.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
